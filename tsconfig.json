{
    "compilerOptions": {
        "target": "ES2017",
        "module": "commonjs",
        "lib": ["ES2017", "DOM"],
        "strict": false,
        "noEmit": true,
        "allowJs": true,
        "checkJs": false,
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "include": ["resources/js/**/*"],
    "exclude": ["node_modules", "vendor", "public"]
}
